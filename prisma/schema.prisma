generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Users {
  id         Int          @id @default(autoincrement())
  name       String
  email      String       @unique
  password   String
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  characters Characters[]
}

model Characters {
  id                    Int      @id @default(autoincrement())
  original_character_id Int
  name                  String
  species               String
  gender                String
  origin                String
  location              String
  image                 String
  status                String
  user_id               Int
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  user                  Users    @relation(fields: [user_id], references: [id])

  @@unique([user_id, original_character_id])
}
